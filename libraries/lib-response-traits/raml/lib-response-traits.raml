#%RAML 1.0 Library
usage: |
  This library is a reusable RAML 1.0 library that defines response traits for use in API
  specifications.

  As part of the Customer API-led reference architecture, it centralizes reusable
  method-level response declarations so APIs can document common request,
  routing, negotiation, and runtime error conditions consistently without
  duplicating response blocks.

  This library is intended to be used in conjunction with:
  - lib-common-responses for the shared response model and response detail types
  - lib-security-traits for security-related requirements such as Client ID Enforcement

uses:
  common: exchange_modules/16339d91-3161-43b4-bef8-7e3fbf0af852/lib-common-responses/1.0.2/lib-common-responses.raml

traits:
  common-routing-errors:
    displayName: Common routing errors
    description: |
      Documents reusable error responses commonly associated with request validation,
      resource resolution, HTTP method handling, and content negotiation.
    responses:
      400:
        description: |
          Bad Request.

          The request could not be processed because it is malformed, missing required inputs,
          contains invalid values, or otherwise does not conform to the API contract.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:00:00Z
              httpStatus: 400
              status: ERROR
              message: Bad request.
              correlationId: 4db53b1e-8c9d-4d2b-980b-a5fdbd1f5f9e
              details:
                - severity: ERROR
                  code: COMMON.REQUEST.INVALID
                  message: Request does not conform to the API contract.
      404:
        description: |
          Not Found.

          The requested resource could not be found.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:01:00Z
              httpStatus: 404
              status: ERROR
              message: Resource not found.
              correlationId: 7f69c032-0eb3-4af4-9a8b-381b2d66197b
              details:
                - severity: ERROR
                  code: COMMON.RESOURCE.NOT_FOUND
                  message: No resource matched the requested URI.
      405:
        description: |
          Method Not Allowed.

          The requested resource exists, but the HTTP method is not supported for that resource.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:02:00Z
              httpStatus: 405
              status: ERROR
              message: Method not allowed.
              correlationId: 8dbaf4d7-9d8c-4019-b319-a19b5a1ee8d1
              details:
                - severity: ERROR
                  code: COMMON.METHOD.NOT_ALLOWED
                  message: The requested HTTP method is not allowed for this resource.
      406:
        description: |
          Not Acceptable.

          The API cannot produce a representation matching the values specified in the Accept header.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:03:00Z
              httpStatus: 406
              status: ERROR
              message: Requested response media type is not acceptable.
              correlationId: 78fba7dc-0323-4cd7-bc8e-594148d8f09b
              details:
                - severity: ERROR
                  code: COMMON.REPRESENTATION.NOT_ACCEPTABLE
                  message: The API cannot produce a representation matching the Accept header.
      415:
        description: |
          Unsupported Media Type.

          The request Content-Type is not supported for the targeted operation.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:04:00Z
              httpStatus: 415
              status: ERROR
              message: Unsupported request media type.
              correlationId: 1c1a4a3f-f65a-4d87-b20b-9d0f17d32499
              details:
                - severity: ERROR
                  code: COMMON.MEDIA_TYPE.UNSUPPORTED
                  message: The request Content-Type is not supported for this operation.
      501:
        description: |
          Not Implemented.

          The operation is declared in the API contract but is not implemented by the service.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:05:00Z
              httpStatus: 501
              status: ERROR
              message: Operation not implemented.
              correlationId: 97d8e9fe-c48f-4986-b7fb-f5dfb3b29c4c
              details:
                - severity: ERROR
                  code: COMMON.OPERATION.NOT_IMPLEMENTED
                  message: The requested operation is declared but not implemented.

  common-routing-and-runtime-errors:
    displayName: Common routing and runtime errors
    description: |
      Documents a reusable set of routing and runtime error responses, including
      the generic internal server error commonly returned when an unexpected
      runtime exception occurs.
    responses:
      400:
        description: |
          Bad Request.

          The request could not be processed because it is malformed, missing required inputs,
          contains invalid values, or otherwise does not conform to the API contract.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:00:00Z
              httpStatus: 400
              status: ERROR
              message: Bad request.
              correlationId: 4db53b1e-8c9d-4d2b-980b-a5fdbd1f5f9e
              details:
                - severity: ERROR
                  code: COMMON.REQUEST.INVALID
                  message: Request does not conform to the API contract.
      404:
        description: |
          Not Found.

          The requested resource could not be found.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:01:00Z
              httpStatus: 404
              status: ERROR
              message: Resource not found.
              correlationId: 7f69c032-0eb3-4af4-9a8b-381b2d66197b
              details:
                - severity: ERROR
                  code: COMMON.RESOURCE.NOT_FOUND
                  message: No resource matched the requested URI.
      405:
        description: |
          Method Not Allowed.

          The requested resource exists, but the HTTP method is not supported for that resource.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:02:00Z
              httpStatus: 405
              status: ERROR
              message: Method not allowed.
              correlationId: 8dbaf4d7-9d8c-4019-b319-a19b5a1ee8d1
              details:
                - severity: ERROR
                  code: COMMON.METHOD.NOT_ALLOWED
                  message: The requested HTTP method is not allowed for this resource.
      406:
        description: |
          Not Acceptable.

          The API cannot produce a representation matching the values specified in the Accept header.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:03:00Z
              httpStatus: 406
              status: ERROR
              message: Requested response media type is not acceptable.
              correlationId: 78fba7dc-0323-4cd7-bc8e-594148d8f09b
              details:
                - severity: ERROR
                  code: COMMON.REPRESENTATION.NOT_ACCEPTABLE
                  message: The API cannot produce a representation matching the Accept header.
      415:
        description: |
          Unsupported Media Type.

          The request Content-Type is not supported for the targeted operation.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:04:00Z
              httpStatus: 415
              status: ERROR
              message: Unsupported request media type.
              correlationId: 1c1a4a3f-f65a-4d87-b20b-9d0f17d32499
              details:
                - severity: ERROR
                  code: COMMON.MEDIA_TYPE.UNSUPPORTED
                  message: The request Content-Type is not supported for this operation.
      500:
        description: |
          Internal Server Error.

          An unexpected error occurred while processing the request.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:06:00Z
              httpStatus: 500
              status: ERROR
              message: An unexpected error occurred.
              correlationId: 8c0dd93b-e9c7-4d50-bce3-9db5bb5df155
              details:
                - severity: ERROR
                  code: SYSTEM.REQUEST.PROCESSING_ERROR
                  message: The request could not be completed because of an unexpected server-side error.
      501:
        description: |
          Not Implemented.

          The operation is declared in the API contract but is not implemented by the service.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:05:00Z
              httpStatus: 501
              status: ERROR
              message: Operation not implemented.
              correlationId: 97d8e9fe-c48f-4986-b7fb-f5dfb3b29c4c
              details:
                - severity: ERROR
                  code: COMMON.OPERATION.NOT_IMPLEMENTED
                  message: The requested operation is declared but not implemented.

  common-validation-and-negotiation-errors:
    displayName: Common validation and negotiation errors
    description: |
      Documents the subset of reusable error responses most commonly associated
      with request validation and content negotiation failures.
    responses:
      400:
        description: |
          Bad Request.

          The request could not be processed because it is malformed, missing required inputs,
          contains invalid values, or otherwise does not conform to the API contract.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:00:00Z
