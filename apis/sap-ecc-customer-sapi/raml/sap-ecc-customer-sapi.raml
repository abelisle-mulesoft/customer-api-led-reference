#%RAML 1.0
title: SAP ECC Customer System API
description: |
  System API for retrieving and synchronizing customer data with SAP ECC. This API abstracts SAP ECC
  technical complexity while preserving alignment with SAP customer master data concepts and
  structures without exposing cryptic backend field names. It exposes SAP ECC customer data using
  readable, SAP-aligned field names rather than the enterprise canonical customer model.
version: v1
mediaType:
  - application/json
protocols:
  - HTTPS

uses:
  common: exchange_modules/16339d91-3161-43b4-bef8-7e3fbf0af852/lib-common-responses/1.0.4/lib-common-responses.raml
  responses: exchange_modules/16339d91-3161-43b4-bef8-7e3fbf0af852/lib-response-traits/1.0.4/lib-response-traits.raml
  security: exchange_modules/16339d91-3161-43b4-bef8-7e3fbf0af852/lib-security-traits/1.0.4/lib-security-traits.raml

/customers:
  displayName: Customers
  description: |
    Collection of SAP ECC customer records represented using an SAP-aligned customer model.

  get:
    displayName: Get customers
    description: Retrieve customer records from SAP ECC.
    is:
      - security.client-id-enforced
      - responses.common-routing-and-runtime-errors
    responses:
      200:
        description: Customer records retrieved.
        body:
          application/json:
            type: GetSapEccCustomersResponse

  post:
    displayName: Upsert customers
    description: Create or update multiple customer records in SAP ECC.
    is:
      - security.client-id-enforced
      - responses.common-routing-and-runtime-errors
    body:
      application/json:
        type: SapEccCustomerCollection
    responses:
      200:
        description: Customer records processed.
        body:
          application/json:
            type: UpsertSapEccCustomersResponse

types:
  SapEccCustomer:
    displayName: SAP ECC Customer
    description: |
      SAP ECC-aligned representation of a customer record. Field names are human-readable, but the
      model remains aligned to SAP ECC customer master concepts rather than the enterprise canonical
      customer model.
    type: object
    additionalProperties: false
    properties:
      sapCustomerNumber:
        type: string
        description: SAP customer number (KUNNR).
      accountGroup?:
        type: string
        description: SAP account group (KTOKD).
      companyCode?:
        type: string
        description: SAP company code (BUKRS).
      salesOrganization?:
        type: string
        description: SAP sales organization (VKORG).
      distributionChannel?:
        type: string
        description: SAP distribution channel (VTWEG).
      division?:
        type: string
        description: SAP division (SPART).
      nameLine1:
        type: string
        description: Customer name line 1 (NAME1).
      nameLine2?:
        type: string
        description: Customer name line 2 (NAME2).
      searchTerm?:
        type: string
        description: Search term used in SAP (SORTL).
      streetAddress?:
        type: string
        description: Street and house number (STRAS).
      city?:
        type: string
        description: City (ORT01).
      region?:
        type: string
        description: Region, state, or province (REGIO).
      postalCode?:
        type: string
        description: Postal code (PSTLZ).
      countryCode?:
        type: string
        description: Country key (LAND1).
      phoneNumber?:
        type: string
        description: Primary telephone number (TELF1).
      emailAddress?:
        type: string
        description: Primary email address.
      taxNumber1?:
        type: string
        description: Tax number 1 (STCD1).
      taxNumber2?:
        type: string
        description: Tax number 2 (STCD2).
      deletionFlag?:
        type: boolean
        description: Indicates the SAP customer record is marked for deletion (LOEVM).
      centralPostingBlock?:
        type: boolean
        description: Indicates the SAP customer record is blocked for central posting (SPERR).
      createdDate?:
        type: date-only
        description: Date the SAP customer record was created (ERDAT).
      createdBy?:
        type: string
        description: SAP user who created the customer record (ERNAM).
      lastChangedDate?:
        type: date-only
        description: Date the SAP customer record was last changed (AEDAT).
    example:
      sapCustomerNumber: "0001001001"
      accountGroup: Z001
      companyCode: "1000"
      salesOrganization: "1000"
      distributionChannel: "10"
      division: "00"
      nameLine1: Acme Corporation
      nameLine2: Northwest Division
      searchTerm: ACME
      streetAddress: 100 Main Street
      city: Seattle
      region: WA
      postalCode: "98101"
      countryCode: US
      phoneNumber: +1-206-555-0100
      emailAddress: ops@acme.example
      taxNumber1: TAX-123456
      deletionFlag: false
      centralPostingBlock: false
      createdDate: 2026-03-12
      createdBy: RFC_USER
      lastChangedDate: 2026-03-15

  SapEccCustomerCollection:
    displayName: SAP ECC Customer Collection
    description: Collection of SAP ECC customer records.
    type: SapEccCustomer[]
    minItems: 1
    example:
      - sapCustomerNumber: "0001001001"
        accountGroup: Z001
        companyCode: "1000"
        salesOrganization: "1000"
        distributionChannel: "10"
        division: "00"
        nameLine1: Acme Corporation
        nameLine2: Northwest Division
        searchTerm: ACME
        streetAddress: 100 Main Street
        city: Seattle
        region: WA
        postalCode: "98101"
        countryCode: US
        phoneNumber: +1-206-555-0100
        emailAddress: ops@acme.example
        taxNumber1: TAX-123456
        deletionFlag: false
        centralPostingBlock: false
        createdDate: 2026-03-12
        createdBy: RFC_USER
        lastChangedDate: 2026-03-15
      - sapCustomerNumber: "0001001002"
        accountGroup: Z002
        companyCode: "1000"
        salesOrganization: "2000"
        distributionChannel: "20"
        division: "00"
        nameLine1: Globex Corporation
        searchTerm: GLOBEX
        streetAddress: 500 Market Street
        city: Bellevue
        region: WA
        postalCode: "98004"
        countryCode: US
        phoneNumber: +1-425-555-0199
        emailAddress: contact@globex.example
        deletionFlag: false
        centralPostingBlock: false
        createdDate: 2026-03-10
        createdBy: RFC_USER
        lastChangedDate: 2026-03-12

  SapEccCustomerGetData:
    displayName: SAP ECC Customer Get Data
    description: SAP ECC customer retrieval payload returned in the standard response envelope.
    type: object
    additionalProperties: false
    properties:
      customers:
        type: SapEccCustomerCollection
        description: Customer records retrieved from SAP ECC.
      recordCount:
        type: integer
        description: Number of customer records returned.
        minimum: 0
    example:
      customers:
        - sapCustomerNumber: "0001001001"
          accountGroup: Z001
          companyCode: "1000"
          salesOrganization: "1000"
          distributionChannel: "10"
          division: "00"
          nameLine1: Acme Corporation
          city: Seattle
          region: WA
          postalCode: "98101"
          countryCode: US
          emailAddress: ops@acme.example
          deletionFlag: false
          centralPostingBlock: false
      recordCount: 1

  SapEccCustomerUpsertData:
    displayName: SAP ECC Customer Upsert Data
    description: SAP ECC customer processing summary returned in the standard response envelope.
    type: object
    additionalProperties: false
    properties:
      recordCount:
        type: integer
        description: Number of customer records received in the request.
        minimum: 0
      createdCount?:
        type: integer
        description: Number of customer records created in SAP ECC.
        minimum: 0
      updatedCount?:
        type: integer
        description: Number of customer records updated in SAP ECC.
        minimum: 0
    example:
      recordCount: 2
      createdCount: 1
      updatedCount: 1

  GetSapEccCustomersResponse:
    displayName: Get SAP ECC Customers Response
    description: Standard API response envelope with an SAP ECC customer retrieval payload.
    type: common.ApiResponse
    properties:
      data?:
        type: SapEccCustomerGetData
    examples:
      success:
        dateTime: 2026-03-17T16:00:00Z
        httpStatus: 200
        status: SUCCESS
        message: Customer records retrieved successfully
        correlationId: 2f6c2b7b-8b1b-4f2d-9ef2-9c6a2a1b0d6a
        data:
          customers:
            - sapCustomerNumber: "0001001001"
              accountGroup: Z001
              companyCode: "1000"
              salesOrganization: "1000"
              distributionChannel: "10"
              division: "00"
              nameLine1: Acme Corporation
              city: Seattle
              region: WA
              postalCode: "98101"
              countryCode: US
              emailAddress: ops@acme.example
              deletionFlag: false
              centralPostingBlock: false
          recordCount: 1

      success-with-warning:
        dateTime: 2026-03-17T22:30:00Z
        httpStatus: 200
        status: WARNING
        message: Request completed with warnings.
        correlationId: 123e4567-e89b-12d3-a456-426614174000
        details:
          - severity: WARNING
            code: CUSTOMER.SKIPPED_INACTIVE
            message: Inactive customers were skipped during retrieval.
        data:
          customers:
            - sapCustomerNumber: "0001001000"
              accountGroup: Z001
              companyCode: "1000"
              salesOrganization: "1000"
              distributionChannel: "10"
              division: "00"
              nameLine1: Acme Corporation
              city: Seattle
              region: WA
              postalCode: "98101"
              countryCode: US
              emailAddress: ops@acme.example
              deletionFlag: false
              centralPostingBlock: false
          recordCount: 1

  UpsertSapEccCustomersResponse:
    displayName: Upsert SAP ECC Customers Response
    description: Standard API response envelope with an SAP ECC customer processing payload.
    type: common.ApiResponse
    properties:
      data?:
        type: SapEccCustomerUpsertData
    example:
      dateTime: 2026-03-17T16:05:00Z
      httpStatus: 200
      status: SUCCESS
      message: Customer records processed successfully
      correlationId: 2f6c2b7b-8b1b-4f2d-9ef2-9c6a2a1b0d6a
      data:
        recordCount: 2
        createdCount: 1
        updatedCount: 1
