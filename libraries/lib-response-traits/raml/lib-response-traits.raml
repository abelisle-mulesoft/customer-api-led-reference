              status: ERROR
              message: Requested response media type is not acceptable.
              correlationId: 78fba7dc-0323-4cd7-bc8e-594148d8f09b
              details:
                - severity: ERROR
                  code: COMMON.REPRESENTATION.NOT_ACCEPTABLE
                  message: The API cannot produce a representation matching the Accept header.
      415:
        description: |
          Unsupported Media Type.

          The request Content-Type is not supported for the targeted operation.
        body:
          application/json:
            type: common.ApiResponse
            example:
              dateTime: 2026-03-24T17:04:00Z
              httpStatus: 415
              status: ERROR
              message: Unsupported request media type.
              correlationId: 1c1a4a3f-f65a-4d87-b20b-9d0f17d32499
              details:
                - severity: ERROR
                  code: COMMON.MEDIA_TYPE.UNSUPPORTED
                  message: The request Content-Type is not supported for this operation.
